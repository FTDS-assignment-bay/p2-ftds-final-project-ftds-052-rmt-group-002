# =============================================================
#  StayWise ML Platform — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# =============================================================


# ─── Airflow Core ────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__LOGGING__REMOTE_LOGGING=False
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs

# Generate fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here


# ─── Airflow Database ─────────────────────────────────────────
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=your_airflow_db_password
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${AIRFLOW_POSTGRES_USER}:${AIRFLOW_POSTGRES_PASSWORD}@postgres-airflow/${AIRFLOW_POSTGRES_DB}
AIRFLOW__DATABASE__LOAD_DEFAULT_CONNECTIONS=False


# ─── Airflow Webserver ────────────────────────────────────────
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True


# ─── Airflow Init ─────────────────────────────────────────────
_AIRFLOW_DB_UPGRADE=True
_AIRFLOW_WWW_USER_CREATE=True
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=your_airflow_ui_password


# ─── Airflow API (untuk Simulator) ───────────────────────────
AIRFLOW_HOST=airflow-webserver
AIRFLOW_PORT=8080
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=your_airflow_ui_password
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth


# ─── MLflow Database ──────────────────────────────────────────
MLFLOW_POSTGRES_USER=mlflow
MLFLOW_POSTGRES_PASSWORD=your_mlflow_db_password
MLFLOW_POSTGRES_DB=mlflow


# ─── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000


# ─── Data Warehouse ───────────────────────────────────────────
# Local  : DW_POSTGRES_HOST=postgres-dw
# VPS    : DW_POSTGRES_HOST=your_vps_ip
DW_POSTGRES_HOST=postgres-dw
DW_POSTGRES_USER=your_dw_user
DW_POSTGRES_PASSWORD=your_dw_password
DW_POSTGRES_DB=datawarehouse


# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=social_sentiment


# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# ─── pgAdmin ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@yourdomain.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password
PGADMIN_CONFIG_SERVER_MODE=False


# ─── Python ───────────────────────────────────────────────────
PYTHONPATH=/opt/airflow/src
